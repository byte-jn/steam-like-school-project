{
  "openapi": "3.0.3",
  "info": {
    "title": "Steam-Like School Project API",
    "version": "1.0.0",
    "description": "REST API for managing users, games, and DLCs in a Steam-like shop system. Provides full CRUD operations for managing digital game products and user accounts.",
    "contact": {
      "name": "WelsyLab",
      "email": "welsylab@outlook.com"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    },
    {
      "url": "http://localhost:8080",
      "description": "Production server",
      "variables": {
        "environment": {
          "default": "prod",
          "enum": ["dev", "prod"]
        }
      }
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "operationId": "alleBenutzerAbrufen",
        "summary": "Retrieve all users",
        "description": "Get a list of all users in the system",
        "tags": ["Benutzer"],
        "responses": {
          "200": {
            "description": "Successfully retrieved users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/BenutzerDto" }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "operationId": "benutzerErstellen",
        "summary": "Create a new user",
        "description": "Create a new user account. Username must be unique.",
        "tags": ["Benutzer"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BenutzerDto" },
              "examples": {
                "newUser": {
                  "value": {
                    "username": "johndoe",
                    "email": "john@example.com",
                    "password": "securepassword123",
                    "firstname": "John",
                    "lastname": "Doe"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BenutzerDto" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": {
            "description": "Username already exists",
            "$ref": "#/components/responses/Conflict"
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/users/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "Datenbank-ID des Benutzers",
          "schema": { "type": "integer", "format": "int64" }
        }
      ],
      "get": {
        "operationId": "benutzerNachIdAbrufen",
        "summary": "Retrieve user by ID",
        "description": "Get a specific user by their database ID",
        "tags": ["Benutzer"],
        "responses": {
          "200": {
            "description": "User found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BenutzerDto" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "put": {
        "operationId": "benutzerAktualisieren",
        "summary": "Update user",
        "description": "Update an existing user's information",
        "tags": ["Benutzer"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BenutzerDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BenutzerDto" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "delete": {
        "operationId": "benutzerLoeschen",
        "summary": "Delete user",
        "description": "Delete a user by their ID",
        "tags": ["Benutzer"],
        "responses": {
          "204": {
            "description": "User deleted successfully"
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/games": {
      "get": {
        "operationId": "alleSpieleAbrufen",
        "summary": "Retrieve all games",
        "description": "Get a list of all available games in the store",
        "tags": ["Spiele"],
        "responses": {
          "200": {
            "description": "Successfully retrieved games",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/SpielDto" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "operationId": "spielErstellen",
        "summary": "Create a new game",
        "description": "Create a new game in the store. ID will be auto-generated if not provided.",
        "tags": ["Spiele"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SpielDto" },
              "examples": {
                "newGame": {
                  "value": {
                    "titel": "The Witcher 3",
                    "description": "Open-world RPG game",
                    "price": 29.99,
                    "releaseDate": 1451606400000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Game created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpielDto" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/games/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "UUID of the game",
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "operationId": "spielNachIdAbrufen",
        "summary": "Retrieve game by ID",
        "description": "Get a specific game by its UUID",
        "tags": ["Spiele"],
        "responses": {
          "200": {
            "description": "Game found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpielDto" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "put": {
        "operationId": "spielAktualisieren",
        "summary": "Update game",
        "description": "Update an existing game's information",
        "tags": ["Spiele"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SpielDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Game updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpielDto" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "delete": {
        "operationId": "spielLoeschen",
        "summary": "Delete game",
        "description": "Delete a game by its UUID",
        "tags": ["Spiele"],
        "responses": {
          "204": {
            "description": "Game deleted successfully"
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/dlcs": {
      "get": {
        "operationId": "alleDlcsAbrufen",
        "summary": "Retrieve all DLCs",
        "description": "Get a list of all available DLCs in the store",
        "tags": ["DLCs"],
        "responses": {
          "200": {
            "description": "Successfully retrieved DLCs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DlcDto" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "operationId": "dlcErstellen",
        "summary": "Create a new DLC",
        "description": "Create a new DLC in the store. ID will be auto-generated if not provided.",
        "tags": ["DLCs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DlcDto" },
              "examples": {
                "newDLC": {
                  "value": {
                    "dlcName": "Blood and Wine",
                    "gameTitle": "The Witcher 3",
                    "description": "Major expansion pack",
                    "price": 14.99,
                    "releaseDate": 1464739200000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "DLC created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DlcDto" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/dlcs/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "UUID of the DLC",
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "operationId": "dlcNachIdAbrufen",
        "summary": "Retrieve DLC by ID",
        "description": "Get a specific DLC by its UUID",
        "tags": ["DLCs"],
        "responses": {
          "200": {
            "description": "DLC found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DlcDto" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "put": {
        "operationId": "dlcAktualisieren",
        "summary": "Update DLC",
        "description": "Update an existing DLC's information",
        "tags": ["DLCs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DlcDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "DLC updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DlcDto" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "delete": {
        "operationId": "dlcLoeschen",
        "summary": "Delete DLC",
        "description": "Delete a DLC by its UUID",
        "tags": ["DLCs"],
        "responses": {
          "204": {
            "description": "DLC deleted successfully"
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid input",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Conflict": {
        "description": "Resource conflict - may violate unique constraints",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message describing what went wrong"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the error occurred"
          },
          "_links": {
            "type": "object",
            "description": "HATEOAS links"
          },
          "_embedded": {
            "type": "object",
            "properties": {
              "errors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "BenutzerDto": {
        "type": "object",
        "description": "User account information",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true,
            "description": "Server-generated database ID. Do not provide when creating a user."
          },
          "username": {
            "type": "string",
            "description": "Unique username (must be unique across all users)",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address"
          },
          "password": {
            "type": "string",
            "writeOnly": true,
            "description": "User's password (only in requests, never in responses)"
          },
          "firstname": {
            "type": "string",
            "description": "User's first name"
          },
          "lastname": {
            "type": "string",
            "description": "User's last name"
          },
          "ownedGamesIds": {
            "type": "array",
            "description": "List of UUIDs of purchased games",
            "items": { "type": "string", "format": "uuid" }
          },
          "ownedDlcIds": {
            "type": "array",
            "description": "List of UUIDs of purchased DLCs",
            "items": { "type": "string", "format": "uuid" }
          }
        }
      },
      "SpielDto": {
        "type": "object",
        "description": "Game product information",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Game UUID. Auto-generated by server if not provided."
          },
          "titel": {
            "type": "string",
            "description": "Game title (field name matches database column 'titel')"
          },
          "description": {
            "type": "string",
            "description": "Game description"
          },
          "price": {
            "type": "number",
            "format": "double",
            "description": "Price in EUR",
            "minimum": 0
          },
          "releaseDate": {
            "type": "integer",
            "format": "int64",
            "description": "Release date as Unix timestamp in milliseconds",
            "example": 1451606400000
          },
          "createdAt": {
            "type": "integer",
            "format": "int64",
            "readOnly": true,
            "description": "Creation timestamp as Unix timestamp in milliseconds. Set by server."
          }
        },
        "required": ["titel", "price"]
      },
      "DlcDto": {
        "type": "object",
        "description": "DLC (Downloadable Content) product information",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "DLC UUID. Auto-generated by server if not provided."
          },
          "dlcName": {
            "type": "string",
            "description": "Name of the DLC"
          },
          "gameTitle": {
            "type": "string",
            "description": "Title of the associated base game"
          },
          "description": {
            "type": "string",
            "description": "DLC description"
          },
          "price": {
            "type": "number",
            "format": "double",
            "description": "Price in EUR",
            "minimum": 0
          },
          "releaseDate": {
            "type": "integer",
            "format": "int64",
            "description": "Release date as Unix timestamp in milliseconds",
            "example": 1464739200000
          },
          "createdAt": {
            "type": "integer",
            "format": "int64",
            "readOnly": true,
            "description": "Creation timestamp as Unix timestamp in milliseconds. Set by server."
          }
        },
        "required": ["dlcName", "gameTitle", "price"]
      }
    }
  }
}
